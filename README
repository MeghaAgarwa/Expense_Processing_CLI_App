Sample outputs of SQL analytics
----------------------------------------------------------------------
SELECT SUM(amount) 
FROM expenses

(Decimal('105606.00'),)

SELECT category,SUM(amount) 
FROM expenses
GROUP BY category

('Bills', Decimal('29252.00'))
('Other', Decimal('1000.00'))
('Transport', Decimal('32380.00'))
('Fun', Decimal('6094.00'))
('Food', Decimal('36880.00'))

SELECT EXTRACT(month from expense_date) AS month_of_year,
SUM(amount) 
FROM expenses 
GROUP BY month_of_year 
ORDER BY month_of_year

(Decimal('1'), Decimal('95048.00'))
(Decimal('2'), Decimal('10058.00'))
(Decimal('3'), Decimal('500.00'))

SELECT *
FROM expenses
WHERE amount =(SELECT MAX(amount) FROM expenses)
ORDER BY expense_date

(91, 'Electricity Bill', 'Monthly bill', Decimal('2150.00'), 'Bills', datetime.date(2024, 1, 30))
(193, 'Electricity Bill', 'Monthly bill', Decimal('2150.00'), 'Bills', datetime.date(2024, 1, 30))



